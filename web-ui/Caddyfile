# malmo-ui static SPA server (WEB_UI.md # deploy model). Serves the built bundle
# from /srv/ui; any path that isn't a real file falls back to index.html so the
# Vue Router (history mode) owns client-side routing. ETag is on by default in
# file_server; `encode` adds gzip + zstd (brotli encoding isn't in the stock
# caddy build — a plugin, deferred).
:80 {
	root * /srv/ui
	encode gzip zstd
	try_files {path} /index.html
	file_server
}
