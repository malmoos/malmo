#!/bin/bash
# Hosted cloud image first-boot wiring (#242), run inside the image (.chroot mode,
# mkosi v27+). Auto-detected for dev/cloud/ — and, because the test lane does
# `Include=..`, mkosi chdir's into dev/cloud/ and runs this for the boot-proof
# image too (so the test image carries the same production wiring it must validate).
#
# Wires the hosted control plane to come up on first boot:
#   - enable docker + containerd, systemd-networkd, host-agent, the first-boot
#     image loader, and the provisioning-seed materializer (.wants symlinks —
#     `systemctl enable` can't run in the chroot);
#   - provision the malmo / malmo-app / malmo-shared identities host-agent +
#     the brain resolve by name (FIRST_RUN.md, APP_ISOLATION.md # Runtime identity);
#   - bring the single virtio NIC up via systemd-networkd DHCP — the minimal
#     cloud-native path, NO NetworkManager (ENVIRONMENT.md # Networking, # Boot);
#   - pre-commit machine-id + mask systemd-firstboot so the interactive wizard
#     never blocks boot.
#
# Deliberately NOT here (hosted cuts, ENVIRONMENT.md # How the profile is realized):
# sshd (off in hosted v1), NetworkManager, Avahi, the LUKS/TPM enrollment of the
# medium lane. The serial-driven boot self-check is test-lane-only — it is enabled
# by dev/cloud/test/mkosi.postinst.chroot, not here.
set -euo pipefail

# Enable a unit by dropping its multi-user.target.wants symlink (no systemctl in
# the chroot). $1 = unit file path (/lib or /etc), $2 = unit name.
enable_unit() {
    mkdir -p /etc/systemd/system/multi-user.target.wants
    ln -sf "$1" "/etc/systemd/system/multi-user.target.wants/$2"
}

# Docker (baked from Docker's apt repo) + its dependency. The brain's compose +
# host-agent's proxy run on it; no physical-disk assembly to order after in hosted.
enable_unit /lib/systemd/system/docker.service     docker.service
enable_unit /lib/systemd/system/containerd.service containerd.service

# systemd-networkd brings the single NIC up (no NM in hosted). Enable it and its
# socket; the .network match below is what actually configures the NIC.
systemctl --root=/ enable systemd-networkd.service >/dev/null 2>&1 || true
# Nothing orders against network-online.target, so don't let wait-online stall boot.
systemctl --root=/ disable systemd-networkd-wait-online.service >/dev/null 2>&1 || true

# Keep systemd-networkd's hands off Docker's own interfaces. The DHCP match below
# is `Type=ether`, which also matches Docker's per-container veth endpoints and the
# docker0 / br-<id> bridges. Left managed, networkd resets them — the bridge ends
# up NO-CARRIER and the veths un-enslaved, so inter-container ARP never resolves
# (the brain can't reach the socket-proxy: "no route to host"). NetworkManager (the
# appliance/medium lane) ignores these by default; networkd does not, so mark them
# unmanaged explicitly. Lower filename prefix → evaluated before 20-dhcp.network,
# so it claims the virtual links first and the real NIC still falls through to DHCP.
mkdir -p /etc/systemd/network
cat > /etc/systemd/network/05-docker-unmanaged.network <<'EOF'
[Match]
Name=docker* veth* br-*

[Link]
Unmanaged=yes
EOF

# Single virtio NIC via DHCP — addressing comes from the cloud's DHCP/metadata
# (ENVIRONMENT.md # Networking, "One virtual NIC"). Match by link type, not a
# slot-dependent predictable name: a cloud VM has exactly one ethernet NIC.
cat > /etc/systemd/network/20-dhcp.network <<'EOF'
[Match]
Type=ether

[Network]
DHCP=yes
EOF

# Static DNS resolver. The lean image ships NO systemd-resolved (not in the
# package set) and systemd-networkd does not itself write /etc/resolv.conf, so
# without this the box gets an IP via DHCP but has NO name resolution — only
# /etc/hosts. That is invisible until something must resolve a public name: the
# box reaches the metadata service and its own :80 by IP, so it boots and serves,
# but the brain's Caddy cannot resolve acme-v02.api.letsencrypt.org or
# auth.malmo.network, so the wildcard-cert ACME flow never starts (#207 / C3b)
# and :443 stays certless. Docker also derives a bridge container's resolver from
# the host's /etc/resolv.conf; with the file absent, malmo-caddy (a malmo-ingress
# container) inherits no usable resolver — the same Docker-DNS gap the cloud
# control-plane deploy had to patch. A static file with public resolvers is the
# no-extra-package fix (resolved would change the lean manifest); the box only
# ever resolves public names (control-plane images are baked, no registry pulls).
cat > /etc/resolv.conf <<'EOF'
# malmo hosted cloud image — static resolver (no systemd-resolved in the lean set).
nameserver 1.1.1.1
nameserver 8.8.8.8
nameserver 9.9.9.9
EOF
chmod 0644 /etc/resolv.conf

# host-agent (slim, -tags hosted) launches the brain; its drop-in (staged in
# mkosi.extra.wiring) points the bootstrap at the baked images + control-plane
# dir. Order-after the image loader lives in that drop-in.
enable_unit /etc/systemd/system/host-agent.service host-agent.service

# First-boot control-plane image loader (reused verbatim from the medium lane).
enable_unit /etc/systemd/system/malmo-load-images.service malmo-load-images.service

# First-boot provisioning-seed materializer (C3a cloud-lane, #220). Lands the
# delivered seed at /var/lib/malmo/seed.json before host-agent launches the brain;
# no-ops on an un-seeded boot.
enable_unit /etc/systemd/system/malmo-seed.service malmo-seed.service

# Block app-container egress to the cloud metadata endpoint (169.254.169.254) so an
# untrusted app container cannot read the first-boot seed secrets via the classic
# cloud-metadata SSRF (#251, ENVIRONMENT.md # Provisioning & first-boot). A standing
# forward-hook nft DROP applied every boot before docker/host-agent start any
# container; the host-root seed fetch (OUTPUT path) is untouched. The unit + ruleset
# are committed static files under mkosi.extra/ (etc/malmo/metadata-firewall.nft).
enable_unit /etc/systemd/system/malmo-metadata-firewall.service malmo-metadata-firewall.service

# Grow the root partition + ext4 to fill the provider disk on boot (systemd-repart
# against /usr/lib/repart.d/50-malmo-grow-root.conf). The image bakes a fixed 8 GiB
# root (mkosi.repart/) so the shipped raw stays small; a provider VM's disk is much
# larger, and without this the box would run on 8 GiB — docker image storage + the
# brain's SQLite store share the volume, so one app install could fill it and 500
# login. Ordered Before=docker/host-agent (in the unit) so the disk is full before
# anything writes to it. Static unit under mkosi.extra/; systemd-repart ships in the
# systemd-repart package (added to the lean set in mkosi.conf). ENVIRONMENT.md # Storage.
enable_unit /etc/systemd/system/malmo-grow-root.service malmo-grow-root.service

# malmo primary group (GID 3000, FIRST_RUN.md # Identity) — new users are created
# with `useradd --gid malmo`; the brain's /setup needs it present. malmo-app /
# malmo-shared (2000/2001, APP_ISOLATION.md # Runtime identity) are the well-known
# app-runtime identities host-agent resolves by name. Idempotent.
getent group malmo        >/dev/null || groupadd -g 3000 malmo
getent group malmo-app    >/dev/null || groupadd -g 2000 malmo-app
getent group malmo-shared >/dev/null || groupadd -g 2001 malmo-shared
getent passwd malmo-app   >/dev/null || useradd -r -u 2000 -g malmo-app \
    -M -d /nonexistent -s /usr/sbin/nologin malmo-app

# Make the staged binaries/scripts executable (ExtraTrees preserves mode, but be
# defensive — a clobbered mode would otherwise fail silently at boot).
chmod 0755 /usr/lib/malmo/host-agent-real 2>/dev/null || true
chmod 0755 /usr/lib/malmo/load-control-plane-images.sh 2>/dev/null || true
chmod 0755 /usr/local/bin/malmo-seed-materialize.sh 2>/dev/null || true

# Leave machine-id empty (zero bytes, file present) so systemd generates a unique
# one on each VM's first real boot. Pre-committing it here would bake the build
# host's entropy into every snapshot — all provisioned VMs would share the same
# machine-id, causing DHCPv6 DUID collisions and indistinguishable journal entries
# when logs are forwarded to a central collector. An empty-but-present file is the
# standard golden-image approach; systemd's machine-id-commit service initializes it
# at runtime without blocking boot.
: > /etc/machine-id
# Mask systemd-firstboot.service so the interactive locale/timezone wizard never
# blocks sysinit (the empty machine-id is not enough to suppress it alone).
systemctl --root=/ mask systemd-firstboot.service >/dev/null 2>&1 || true
