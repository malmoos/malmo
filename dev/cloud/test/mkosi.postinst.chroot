#!/bin/bash
# Boot-proof image postinst (C2 #205; slimmed #242), run inside the image (.chroot
# mode, mkosi v27+). Auto-detected for THIS config dir (dev/cloud/test).
#
# Since #242 promoted the first-boot runtime wiring into the production image, that
# wiring (enable docker/networkd/host-agent/seed/load-images, the NIC DHCP config,
# the malmo identities, the firstboot mask) is now done by dev/cloud/mkosi.postinst.
# chroot — which mkosi ALSO runs for this lane, because dev/cloud/test/mkosi.conf
# does `Include=..` (mkosi chdir's into dev/cloud/ and runs its auto-detected
# postinst too). So all this lane adds on top is the serial-driven boot self-check.
set -euo pipefail

# Enable a unit by dropping its multi-user.target.wants symlink (no systemctl in
# the chroot). $1 = unit file path, $2 = unit name.
enable_unit() {
    mkdir -p /etc/systemd/system/multi-user.target.wants
    ln -sf "$1" "/etc/systemd/system/multi-user.target.wants/$2"
}

# The serial-driven boot self-check (C2). Runs once after the stack should be up,
# polls it, and writes its verdict to /dev/console for the QEMU harness to grep.
# Test-lane only — the production image ships no assertions oneshot.
enable_unit /etc/systemd/system/malmo-cloud-assertions.service malmo-cloud-assertions.service

# Make the staged self-check executable (ExtraTrees preserves mode, but be
# defensive — a clobbered mode would otherwise fail silently at boot).
chmod 0755 /usr/local/bin/cloud-assertions.sh 2>/dev/null || true
