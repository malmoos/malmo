#!/bin/bash
# Runs inside the image as a chroot (.chroot extension = mkosi v27+
# chroot mode; the image root is mounted at /). After package install +
# ExtraTrees copy, before image finalization.
#
# Responsibilities for slice 0021:
#   - Enable molma-storage-ready.target via .wants symlink.
#   - Ensure /run/molma/health/ exists via tmpfiles.d (cleaner than
#     the reporter's mkdir -p; tracked as a known gap in 0019).
#   - Make the storage-verify binary executable.
#   - Enable sshd and disable host-agent.service (host-agent-real is
#     /bin/true here; its RuntimeDirectory=molma would delete
#     /run/molma/ on exit, destroying storage.json before assertions).
#   - Pre-commit machine-id + mask systemd-firstboot so the interactive
#     firstboot wizard doesn't block sysinit.target.
#   - System preset file: enable ssh.service, disable host-agent.service.
#   - Enable systemd-networkd + DHCP config for the virtio NIC.
set -euo pipefail

# Enable storage-ready target. The .wants symlink would normally be
# created by `systemctl enable`, but in the chroot we can't run
# systemctl — drop the symlink manually.
mkdir -p /etc/systemd/system/multi-user.target.wants
ln -sf /etc/systemd/system/molma-storage-ready.target \
    /etc/systemd/system/multi-user.target.wants/molma-storage-ready.target

# tmpfiles.d entry for /run/molma/health (cleaner than the reporter's
# mkdir -p; see 0019 known gaps).
mkdir -p /etc/tmpfiles.d
cat >/etc/tmpfiles.d/molma.conf <<'EOF'
d /run/molma 0755 root root -
d /run/molma/health 0755 root root -
EOF

# Ensure storage-verify is executable. ExtraTrees should preserve mode
# but be defensive.
chmod 0755 /usr/lib/molma/molma-storage-verify

# First-boot TPM2 enrollment unit (slice 0023 Stage 2). The unit declares
# WantedBy=molma-storage-ready.target; we can't run `systemctl enable` in
# the chroot, so drop the .wants symlink manually (same idiom as the
# storage-ready target above). It's a run-once oneshot gated on a marker,
# so it self-disables after the first successful enroll.
chmod 0755 /usr/lib/molma/first-boot-tpm-enroll.sh
mkdir -p /etc/systemd/system/molma-storage-ready.target.wants
ln -sf /etc/systemd/system/molma-tpm-enroll.service \
    /etc/systemd/system/molma-storage-ready.target.wants/molma-tpm-enroll.service

# sshd: key-only root login. (sshd_config drop-in is in mkosi.extra/.)
chmod 0700 /root/.ssh 2>/dev/null || true
chmod 0600 /root/.ssh/authorized_keys 2>/dev/null || true
# Enable sshd at boot — package install doesn't auto-enable in mkosi.
# (The preset file below also enables it for first-boot preset-all runs.)
ln -sf /lib/systemd/system/ssh.service \
    /etc/systemd/system/multi-user.target.wants/ssh.service

# Disable services we don't want eating boot time / pulling in deps.
systemctl --root=/ disable systemd-networkd-wait-online.service \
    >/dev/null 2>&1 || true

# Pre-commit machine-id so systemd doesn't treat first VM boot as "first boot".
# systemd detects first boot via an empty/uninitialized /etc/machine-id; that
# triggers the interactive firstboot wizard which blocks sysinit.target while
# waiting for user input (races with our SSH poll window).
# systemd-machine-id-setup (no --commit) writes a fresh valid ID.
# Fallback: /proc/sys/kernel/random/uuid is always available in the tools image.
systemd-machine-id-setup 2>/dev/null || \
    { tr -d '-\n' < /proc/sys/kernel/random/uuid > /etc/machine-id && echo >> /etc/machine-id; }
# Belt-and-suspenders: mask the unit too so even if detection fires it's a no-op.
systemctl --root=/ mask systemd-firstboot.service >/dev/null 2>&1 || true

# Preset file so systemctl-preset-all on first boot keeps ssh enabled and
# keeps host-agent.service disabled. host-agent.service has WantedBy=multi-user.target
# so mkosi's preset-all would enable it; but host-agent-real is /bin/true in this
# image and host-agent.service has RuntimeDirectory=molma which causes systemd to
# remove /run/molma/ (including health/storage.json) when the service exits.
mkdir -p /usr/lib/systemd/system-preset
cat > /usr/lib/systemd/system-preset/99-molma-medium-test.preset <<'EOF'
enable ssh.service
disable host-agent.service
EOF
# Belt-and-suspenders: remove any enable symlink already created during build.
systemctl --root=/ disable host-agent.service >/dev/null 2>&1 || true

# Enable networkd and configure DHCP so the VM gets an IP and sshd is reachable.
# virtio-net shows up as enp0s2 in the guest; the wildcard Match covers that
# and any other ethernet-like name.
systemctl --root=/ enable systemd-networkd.service >/dev/null 2>&1 || true
mkdir -p /etc/systemd/network
cat > /etc/systemd/network/20-dhcp.network << 'EOF'
[Match]
Name=en* eth*

[Network]
DHCP=yes
EOF
