#!/bin/bash
# Runs inside the image as a chroot (.chroot extension = mkosi v27+
# chroot mode; the image root is mounted at /). After package install +
# ExtraTrees copy, before image finalization.
#
# Responsibilities for slice 0021:
#   - Enable malmo-storage-ready.target via .wants symlink.
#   - Ensure /run/malmo/health/ exists via tmpfiles.d (cleaner than
#     the reporter's mkdir -p; tracked as a known gap in 0019).
#   - Make the storage-verify binary executable.
#   - Enable sshd and host-agent.service (#164: host-agent-real is now
#     the real binary that launches the brain container; it runs long
#     so RuntimeDirectory=malmo stays put — the /bin/true-exits hazard
#     that kept it disabled is gone).
#   - Pre-commit machine-id + mask systemd-firstboot so the interactive
#     firstboot wizard doesn't block sysinit.target.
#   - System preset file: enable ssh.service and host-agent.service.
#   - Enable systemd-networkd + DHCP config for the virtio NIC.
set -euo pipefail

# Enable storage-ready target. The .wants symlink would normally be
# created by `systemctl enable`, but in the chroot we can't run
# systemctl — drop the symlink manually.
mkdir -p /etc/systemd/system/multi-user.target.wants
ln -sf /etc/systemd/system/malmo-storage-ready.target \
    /etc/systemd/system/multi-user.target.wants/malmo-storage-ready.target

# malmo primary group (#166). New users are created with `useradd --gid malmo`
# (internal/hostagent/usermgr defaults PrimaryGroup to "malmo"), so the group
# must exist before the headless /setup runs. GID 3000 per FIRST_RUN.md #
# Identity & display names (the malmo-reserved range); idempotent so a rebuild
# over an existing tree is a no-op. The `sudo` group is provisioned by the sudo
# package (mkosi.conf), so SetRole's admin -> sudo add has its target too.
getent group malmo >/dev/null || groupadd -g 3000 malmo

# /etc/pam.d/malmo staged into the image overlay by bootstrap.sh (dev/pam/malmo).

# tmpfiles.d entry for /run/malmo/health (cleaner than the reporter's
# mkdir -p; see 0019 known gaps).
mkdir -p /etc/tmpfiles.d
cat >/etc/tmpfiles.d/malmo.conf <<'EOF'
d /run/malmo 0755 root root -
d /run/malmo/health 0755 root root -
EOF

# Ensure storage-verify is executable. ExtraTrees should preserve mode
# but be defensive.
chmod 0755 /usr/lib/malmo/malmo-storage-verify

# First-boot TPM2 enrollment unit (slice 0023 Stage 2). The unit declares
# WantedBy=malmo-storage-ready.target; we can't run `systemctl enable` in
# the chroot, so drop the .wants symlink manually (same idiom as the
# storage-ready target above). It's a run-once oneshot gated on a marker,
# so it self-disables after the first successful enroll.
chmod 0755 /usr/lib/malmo/first-boot-tpm-enroll.sh
mkdir -p /etc/systemd/system/malmo-storage-ready.target.wants
ln -sf /etc/systemd/system/malmo-tpm-enroll.service \
    /etc/systemd/system/malmo-storage-ready.target.wants/malmo-tpm-enroll.service

# sshd: key-only root login. (sshd_config drop-in is in mkosi.extra/.)
chmod 0700 /root/.ssh 2>/dev/null || true
chmod 0600 /root/.ssh/authorized_keys 2>/dev/null || true
# Enable sshd at boot — package install doesn't auto-enable in mkosi.
# (The preset file below also enables it for first-boot preset-all runs.)
ln -sf /lib/systemd/system/ssh.service \
    /etc/systemd/system/multi-user.target.wants/ssh.service

# Disable services we don't want eating boot time / pulling in deps.
systemctl --root=/ disable systemd-networkd-wait-online.service \
    >/dev/null 2>&1 || true

# Pre-commit machine-id so systemd doesn't treat first VM boot as "first boot".
# systemd detects first boot via an empty/uninitialized /etc/machine-id; that
# triggers the interactive firstboot wizard which blocks sysinit.target while
# waiting for user input (races with our SSH poll window).
# systemd-machine-id-setup (no --commit) writes a fresh valid ID.
# Fallback: /proc/sys/kernel/random/uuid is always available in the tools image.
systemd-machine-id-setup 2>/dev/null || \
    { tr -d '-\n' < /proc/sys/kernel/random/uuid > /etc/machine-id && echo >> /etc/machine-id; }
# Belt-and-suspenders: mask the unit too so even if detection fires it's a no-op.
systemctl --root=/ mask systemd-firstboot.service >/dev/null 2>&1 || true

# Preset file so systemctl-preset-all on first boot keeps ssh + host-agent
# enabled. host-agent.service has WantedBy=multi-user.target; #164 runs the real
# host-agent-real (which launches the brain), and it stays running, so the
# RuntimeDirectory=malmo teardown that the old /bin/true stub triggered on exit
# no longer applies — the unit is enabled.
mkdir -p /usr/lib/systemd/system-preset
cat > /usr/lib/systemd/system-preset/99-malmo-medium-test.preset <<'EOF'
enable ssh.service
enable NetworkManager.service
enable avahi-daemon.service
enable docker.service
enable containerd.service
enable malmo-load-images.service
enable host-agent.service
disable NetworkManager-wait-online.service
EOF
# Belt-and-suspenders: drop the .wants symlink manually (can't run
# `systemctl enable` in the chroot), same idiom as the other units above.
ln -sf /etc/systemd/system/host-agent.service \
    /etc/systemd/system/multi-user.target.wants/host-agent.service

# Docker + first-boot control-plane image load (#163). docker-ce is baked from
# Docker's apt repo; enable docker.service (ordered After=malmo-storage-ready.
# target via the drop-in staged in mkosi.extra) and the run-once image-load
# oneshot. As elsewhere, we can't `systemctl enable` in the chroot — drop the
# .wants symlinks manually (the preset above is the belt-and-suspenders half).
chmod 0755 /usr/lib/malmo/load-control-plane-images.sh
ln -sf /lib/systemd/system/docker.service \
    /etc/systemd/system/multi-user.target.wants/docker.service
ln -sf /lib/systemd/system/containerd.service \
    /etc/systemd/system/multi-user.target.wants/containerd.service
ln -sf /etc/systemd/system/malmo-load-images.service \
    /etc/systemd/system/multi-user.target.wants/malmo-load-images.service

# Networking is split by MAC between networkd and NetworkManager (#130):
# the first NIC (52:54:00:6d:6c:01, pinned in run-medium-tests.sh) carries
# SSH via networkd DHCP exactly as before and is marked NM-unmanaged so the
# two daemons never fight over it. The other two NICs are NetworkManager's
# — the network-state slice under test reads the LAN set from NM, and the
# in-VM assertions flip their state without ever touching the SSH path.
# MAC matching, not interface names: predictable names depend on PCI slot
# assignment, MACs are pinned in the QEMU args.
systemctl --root=/ enable systemd-networkd.service >/dev/null 2>&1 || true
mkdir -p /etc/systemd/network
cat > /etc/systemd/network/20-dhcp.network << 'EOF'
[Match]
MACAddress=52:54:00:6d:6c:01

[Network]
DHCP=yes
EOF
mkdir -p /etc/NetworkManager/conf.d
cat > /etc/NetworkManager/conf.d/90-malmo-medium-test.conf << 'EOF'
[keyfile]
unmanaged-devices=mac:52:54:00:6d:6c:01
EOF
systemctl --root=/ enable NetworkManager.service >/dev/null 2>&1 || true
systemctl --root=/ enable avahi-daemon.service >/dev/null 2>&1 || true
# Same posture as systemd-networkd-wait-online above: nothing in the image
# orders against network-online.target, so don't let it slow the boot.
systemctl --root=/ disable NetworkManager-wait-online.service >/dev/null 2>&1 || true
