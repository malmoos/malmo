# Go
/bin/
*.test
*.out

# Build artifacts — cmd binaries built at repo root
/host-agent
/host-agent-real
/brain
/malmo-storage-verify
/malmo

# malmo dev state (instance dirs, sqlite, generated compose)
/.dev/

# Node / Vite
web-ui/node_modules/
web-ui/dist/
